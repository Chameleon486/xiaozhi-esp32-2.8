{
    "name": "QDtech ES3N28P",
    "description": "2.8 inch IPS display without touch, ESP32-S3",
    "target": "esp32s3",
    "builds": [
        {
            "name": "qdtech-es3n28p",
            "sdkconfig_append": [
                "CONFIG_LCD_TYPE_ILI9341=y",
                "CONFIG_LCD_SPI_CLK=12",
                "CONFIG_LCD_SPI_MOSI=11",
                "CONFIG_LCD_SPI_MISO=13",
                "CONFIG_LCD_CS=10",
                "CONFIG_LCD_DC=46",
                "CONFIG_LCD_RST=-1",
                "CONFIG_LCD_BL=45",
                "CONFIG_LCD_BACKLIGHT_ENABLED=y",
                "CONFIG_LCD_BACKLIGHT_ON_LEVEL=y",
                "CONFIG_LCD_MIRROR_X=n",
                "CONFIG_LCD_MIRROR_Y=n",
                "CONFIG_LCD_SWAP_XY=n",
                "CONFIG_LCD_OFFSET_X=0",
                "CONFIG_LCD_OFFSET_Y=0",
                "CONFIG_LCD_TOUCH_ENABLED=n",
                "CONFIG_AUDIO_CODEC_ES8311=y",
                "CONFIG_AUDIO_I2C_SDA=16",
                "CONFIG_AUDIO_I2C_SCL=15",
                "CONFIG_AUDIO_I2S_BCK=5",
                "CONFIG_AUDIO_I2S_WS=7",
                "CONFIG_AUDIO_I2S_DOUT=6",
                "CONFIG_AUDIO_I2S_DIN=8",
                "CONFIG_AUDIO_SPEAKER_ENABLE=1",
                "CONFIG_AUDIO_MIC_ENABLE=1",
                "CONFIG_SD_CARD_ENABLED=y",
                "CONFIG_SD_CLK=38",
                "CONFIG_SD_CMD=40",
                "CONFIG_SD_D0=39",
                "CONFIG_SD_D1=41",
                "CONFIG_SD_D2=48",
                "CONFIG_SD_D3=47",
                "CONFIG_RGB_LED_ENABLED=y",
                "CONFIG_RGB_LED_PIN=42",
                "CONFIG_BATTERY_ADC_ENABLED=n"
            ]
        }
    ]
}
